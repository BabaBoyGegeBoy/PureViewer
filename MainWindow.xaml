<Window x:Class="PureViewer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PureViewer" Height="600" Width="1000"
        Background="#FF2E2E2E"
        KeyDown="Window_KeyDown"
        MouseWheel="Window_MouseWheel"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#FF555555"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#FF666666"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1" Padding="{TemplateBinding Padding}"
                                CornerRadius="3">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FF777777"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ListViewItem">
            <Setter Property="Foreground" Value="#FFCCCCCC"/>
            <Setter Property="Background" Value="Transparent"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#FF555555"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FF4A4A4A"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <DataTemplate x:Key="ThumbTemplate">
            <Border Background="#FF2A2A2A" Margin="4" CornerRadius="4" Width="140">
                <StackPanel>
                    <Image Source="{Binding Thumbnail}" Width="120" Height="120"
                           Stretch="Uniform" Margin="8,8,8,4"/>
                    <TextBlock Text="{Binding FileName}" Foreground="#FFAAAAAA" FontSize="10"
                               TextTrimming="CharacterEllipsis" TextWrapping="NoWrap"
                               HorizontalAlignment="Center" Margin="4,0,4,6"/>
                </StackPanel>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <DockPanel Background="#FF2E2E2E">

        <!-- ── Top: Minimal toolbar (28px) ─────────────────── -->
        <Border DockPanel.Dock="Top" Background="#FF383838" Height="28"
                BorderBrush="#FF444444" BorderThickness="0,0,0,1">
            <Grid Margin="6,0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="📁" Click="SelectFolder_Click" Padding="6,1"
                            Margin="0,0,4,0" FontSize="12" ToolTip="选择文件夹"/>
                    <CheckBox x:Name="IncludeSubfolders" VerticalAlignment="Center"
                              Foreground="#FFCCCCCC" FontSize="11" Content="子文件夹" Margin="0,0,6,0"/>
                    <TextBlock x:Name="FolderText" VerticalAlignment="Center"
                               Foreground="#FFCCCCCC" FontSize="11"
                               Text="未选择文件夹" Margin="0,0,8,0"/>
                    <TextBox x:Name="SearchBox" Width="150" VerticalAlignment="Center"
                             Background="#FF4A4A4A" Foreground="#FFCCCCCC" BorderBrush="#FF666666"
                             Padding="4,1" FontSize="11" Tag="搜索…"
                             TextChanged="SearchBox_TextChanged"
                             GotFocus="SearchBox_GotFocus" LostFocus="SearchBox_LostFocus"/>
                    <ComboBox x:Name="TagFilter" Width="130" VerticalAlignment="Center"
                              Margin="6,0,0,0" Background="#FF4A4A4A" Foreground="#FFCCCCCC"
                              BorderBrush="#FF666666" Padding="4,1" FontSize="11"
                              SelectionChanged="TagFilter_SelectionChanged"/>
                </StackPanel>
                <!-- Right side: page info + zoom -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center"
                            HorizontalAlignment="Right">
                    <TextBlock x:Name="PageInfo" Foreground="#FF999999" FontSize="11"
                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock x:Name="ZoomText" Text="100%" Foreground="#FF888888"
                               FontSize="10" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ── Bottom: Collapsible control bar ─────────────── -->
        <Border DockPanel.Dock="Bottom" x:Name="BottomBar" Background="#FF383838"
                BorderBrush="#FF444444" BorderThickness="0,1,0,0"
                Height="0" ClipToBounds="True">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"
                        VerticalAlignment="Center" Margin="0,4">
                <Button Content="◀ 上一张" Click="Prev_Click" Margin="3" Padding="10,3"/>
                <Button Content="下一张 ▶" Click="Next_Click" Margin="3" Padding="10,3"/>
                <Button Content="全屏" Click="Fullscreen_Click" Margin="3" Padding="10,3"/>
                <Button Content="退出全屏" Click="ExitFullscreen_Click" Margin="3" Padding="10,3"/>
                <Button x:Name="ToggleViewBtn" Content="缩略图" Click="ToggleView_Click"
                        Margin="12,3,3,3" Padding="10,3"/>
            </StackPanel>
        </Border>

        <!-- Bottom hover trigger: invisible strip at bottom edge -->
        <Border DockPanel.Dock="Bottom" Height="6" Background="Transparent"
                x:Name="BottomTrigger"
                MouseEnter="BottomTrigger_MouseEnter"/>

        <!-- ── Left: Author sidebar (Tab toggle) ───────────── -->
        <Border DockPanel.Dock="Left" x:Name="AuthorSidebar" Width="170"
                Background="#FF333333" BorderBrush="#FF444444" BorderThickness="0,0,1,0"
                Visibility="Collapsed">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="作者列表" Foreground="#FFCCCCCC"
                           FontSize="12" Margin="6,4" FontWeight="Bold"/>
                <ListView x:Name="AuthorList" SelectionChanged="AuthorList_SelectionChanged"
                          Background="Transparent" BorderThickness="0"
                          Foreground="#FFCCCCCC" FontSize="11" Margin="2"/>
            </DockPanel>
        </Border>

        <!-- ── Center: Image / Thumbnail area ──────────────── -->
        <Grid>
            <!-- Reading view -->
            <Grid x:Name="ImageContainer" ClipToBounds="True">
                <ScrollViewer x:Name="ImageScroll" HorizontalScrollBarVisibility="Disabled"
                              VerticalScrollBarVisibility="Disabled" Background="#FF2E2E2E"
                              PreviewMouseWheel="ImageScroll_PreviewMouseWheel">
                    <Image x:Name="ImageViewer" Stretch="Uniform"
                           RenderTransformOrigin="0.5,0.5"
                           MouseLeftButtonDown="ImageViewer_MouseLeftButtonDown"
                           MouseLeftButtonUp="ImageViewer_MouseLeftButtonUp"
                           MouseMove="ImageViewer_MouseMove">
                        <Image.RenderTransform>
                            <ScaleTransform x:Name="ImageScale" ScaleX="1" ScaleY="1"/>
                        </Image.RenderTransform>
                    </Image>
                </ScrollViewer>
                <TextBlock x:Name="LoadingText" Text="加载中…"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           Foreground="#FFAAAAAA" FontSize="18" Visibility="Collapsed"/>
            </Grid>

            <!-- Grid view (thumbnails) -->
            <ListView x:Name="ThumbGrid" Visibility="Collapsed"
                      ItemTemplate="{StaticResource ThumbTemplate}"
                      SelectionChanged="ThumbGrid_SelectionChanged"
                      Background="#FF2E2E2E" BorderThickness="0"
                      Foreground="#FFCCCCCC"
                      ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListView.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel IsItemsHost="True"/>
                    </ItemsPanelTemplate>
                </ListView.ItemsPanel>
            </ListView>
        </Grid>
    </DockPanel>
</Window>
