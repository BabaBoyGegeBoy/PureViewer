<Window x:Class="PureViewer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PureViewer" Height="600" Width="1000"
        Background="#FF3C3C3C"
        KeyDown="Window_KeyDown"
        MouseWheel="Window_MouseWheel"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#FF555555"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#FF666666"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1" Padding="{TemplateBinding Padding}"
                                CornerRadius="3">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FF777777"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ListViewItem">
            <Setter Property="Foreground" Value="#FFCCCCCC"/>
            <Setter Property="Background" Value="Transparent"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#FF555555"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FF4A4A4A"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <!-- Thumbnail card style -->
        <DataTemplate x:Key="ThumbTemplate">
            <Border Background="#FF2A2A2A" Margin="4" CornerRadius="4" Width="140">
                <StackPanel>
                    <Image Source="{Binding Thumbnail}" Width="120" Height="120"
                           Stretch="Uniform" Margin="8,8,8,4"/>
                    <TextBlock Text="{Binding FileName}" Foreground="#FFAAAAAA" FontSize="10"
                               TextTrimming="CharacterEllipsis" TextWrapping="NoWrap"
                               HorizontalAlignment="Center" Margin="4,0,4,6"/>
                </StackPanel>
            </Border>
        </DataTemplate>
    </Window.Resources>
    <DockPanel Background="#FF3C3C3C">
        <!-- Top: Folder selection + search -->
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="8">
            <Button Content="选择文件夹" Click="SelectFolder_Click"
                    Padding="12,6" Margin="0,0,8,0"/>
            <CheckBox x:Name="IncludeSubfolders" VerticalAlignment="Center"
                      Foreground="#FFCCCCCC" Content="含子文件夹" Margin="0,0,8,0"/>
            <TextBlock x:Name="FolderText" VerticalAlignment="Center" Foreground="#FFCCCCCC"
                       Text="未选择文件夹" FontSize="13" Margin="0,0,12,0"/>
            <TextBox x:Name="SearchBox" Width="200" VerticalAlignment="Center"
                     Background="#FF4A4A4A" Foreground="#FFCCCCCC" BorderBrush="#FF666666"
                     Padding="6,4" Tag="搜索文件名…"
                     TextChanged="SearchBox_TextChanged"
                     GotFocus="SearchBox_GotFocus" LostFocus="SearchBox_LostFocus"/>
            <ComboBox x:Name="TagFilter" Width="160" VerticalAlignment="Center"
                      Margin="8,0,0,0" Background="#FF4A4A4A" Foreground="#FFCCCCCC"
                      BorderBrush="#FF666666" Padding="6,4"
                      SelectionChanged="TagFilter_SelectionChanged"/>
        </StackPanel>

        <!-- Bottom: Controls -->
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                    HorizontalAlignment="Center" Margin="8">
            <Button Content="◀ 上一张 (←/A)" Click="Prev_Click" Margin="4" Padding="12,6"/>
            <Button Content="下一张 (→/D) ▶" Click="Next_Click" Margin="4" Padding="12,6"/>
            <Button Content="全屏 (F11)" Click="Fullscreen_Click" Margin="4" Padding="12,6"/>
            <Button Content="退出全屏 (Esc)" Click="ExitFullscreen_Click" Margin="4" Padding="12,6"/>
            <Button x:Name="ToggleViewBtn" Content="缩略图 (G)" Click="ToggleView_Click" Margin="12,4,4,4" Padding="12,6"/>
        </StackPanel>

        <!-- Left: Author list sidebar -->
        <DockPanel DockPanel.Dock="Left" Width="180" Background="#FF333333"
                   x:Name="AuthorSidebar" Visibility="Collapsed">
            <TextBlock DockPanel.Dock="Top" Text="作者列表" Foreground="#FFCCCCCC"
                       FontSize="13" Margin="8,6" FontWeight="Bold"/>
            <ListView x:Name="AuthorList" SelectionChanged="AuthorList_SelectionChanged"
                      Background="Transparent" BorderThickness="0"
                      Foreground="#FFCCCCCC" FontSize="12" Margin="2"/>
        </DockPanel>

        <!-- Center: View switcher -->
        <Grid Margin="4">
            <!-- Reading view (image + zoom/pan) -->
            <Grid x:Name="ImageContainer" ClipToBounds="True">
                <ScrollViewer x:Name="ImageScroll" HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Auto" Background="#FF3C3C3C"
                              PreviewMouseWheel="ImageScroll_PreviewMouseWheel">
                    <Image x:Name="ImageViewer" Stretch="Uniform"
                           RenderTransformOrigin="0.5,0.5"
                           MouseLeftButtonDown="ImageViewer_MouseLeftButtonDown"
                           MouseLeftButtonUp="ImageViewer_MouseLeftButtonUp"
                           MouseMove="ImageViewer_MouseMove">
                        <Image.RenderTransform>
                            <ScaleTransform x:Name="ImageScale" ScaleX="1" ScaleY="1"/>
                        </Image.RenderTransform>
                    </Image>
                </ScrollViewer>
                <TextBlock x:Name="LoadingText" Text="加载中…"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           Foreground="#FFAAAAAA" FontSize="18" Visibility="Collapsed"/>
                <TextBlock x:Name="ZoomText" Text="100%"
                           HorizontalAlignment="Right" VerticalAlignment="Bottom"
                           Foreground="#FF888888" FontSize="11" Margin="8"/>
            </Grid>

            <!-- Grid view (thumbnails) -->
            <ListView x:Name="ThumbGrid" Visibility="Collapsed"
                      ItemTemplate="{StaticResource ThumbTemplate}"
                      SelectionChanged="ThumbGrid_SelectionChanged"
                      Background="#FF3C3C3C" BorderThickness="0"
                      Foreground="#FFCCCCCC"
                      ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListView.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel IsItemsHost="True"/>
                    </ItemsPanelTemplate>
                </ListView.ItemsPanel>
            </ListView>
        </Grid>
    </DockPanel>
</Window>
