<Window x:Class="PureViewer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PureViewer" Height="600" Width="1000"
        Background="#FF1E1E1E"
        KeyDown="Window_KeyDown"
        MouseWheel="Window_MouseWheel"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#FF555555"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#FF666666"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1" Padding="{TemplateBinding Padding}"
                                CornerRadius="3">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FF777777"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ListViewItem">
            <Setter Property="Foreground" Value="#FFCCCCCC"/>
            <Setter Property="Background" Value="Transparent"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#FF555555"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FF4A4A4A"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <DataTemplate x:Key="ThumbTemplate">
            <Border Background="#FF2A2A2A" Margin="4" CornerRadius="4" Width="140">
                <StackPanel>
                    <Image Source="{Binding Thumbnail}" Width="120" Height="120"
                           Stretch="Uniform" Margin="8,8,8,4"/>
                    <TextBlock Text="{Binding FileName}" Foreground="#FFAAAAAA" FontSize="10"
                               TextTrimming="CharacterEllipsis" TextWrapping="NoWrap"
                               HorizontalAlignment="Center" Margin="4,0,4,6"/>
                </StackPanel>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <!-- Right-click context menu -->
    <Window.ContextMenu>
        <ContextMenu x:Name="MainContextMenu" Background="#FF333333" Foreground="#FFCCCCCC"
                     BorderBrush="#FF555555">
            <MenuItem Header="选择文件夹..." Click="Menu_SelectFolder"/>
            <MenuItem Header="含子文件夹" x:Name="MenuIncludeSubfolders" IsCheckable="True"/>
            <Separator/>
            <MenuItem Header="上一张 (←/A)" Click="Menu_Prev"/>
            <MenuItem Header="下一张 (→/D)" Click="Menu_Next"/>
            <Separator/>
            <MenuItem Header="全屏 (F11)" Click="Menu_EnterFullscreen"/>
            <MenuItem Header="退出全屏 (Esc)" Click="Menu_ExitFullscreen"/>
            <MenuItem Header="缩略图视图 (G)" Click="Menu_ToggleView"/>
            <Separator/>
            <MenuItem Header="搜索... (Ctrl+F)" Click="Menu_OpenSearch"/>
            <MenuItem Header="标签筛选..." Click="Menu_OpenTagFilter"/>
            <MenuItem Header="作者列表 (Tab)" Click="Menu_ToggleSidebar"/>
        </ContextMenu>
    </Window.ContextMenu>

    <!-- Root: full-window image with overlay popups -->
    <Grid x:Name="RootGrid" Background="#FF1E1E1E"
>

        <!-- Layer 1: Image viewer (full window) -->
        <ScrollViewer x:Name="ImageScroll" HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Disabled" Background="#FF1E1E1E"
                      PreviewMouseWheel="ImageScroll_PreviewMouseWheel">
            <Image x:Name="ImageViewer" Stretch="Uniform"
                   RenderTransformOrigin="0.5,0.5"
                   MouseLeftButtonDown="ImageViewer_MouseLeftButtonDown"
                   MouseLeftButtonUp="ImageViewer_MouseLeftButtonUp"
                   MouseMove="ImageViewer_MouseMove">
                <Image.RenderTransform>
                    <ScaleTransform x:Name="ImageScale" ScaleX="1" ScaleY="1"/>
                </Image.RenderTransform>
            </Image>
        </ScrollViewer>

        <!-- Layer 2: Thumbnail grid (full window) -->
        <ListView x:Name="ThumbGrid" Visibility="Collapsed"
                  ItemTemplate="{StaticResource ThumbTemplate}"
                  SelectionChanged="ThumbGrid_SelectionChanged"
                  Background="#FF1E1E1E" BorderThickness="0"
                  Foreground="#FFCCCCCC"
                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                  ScrollViewer.ScrollChanged="ThumbGrid_ScrollChanged">
            <ListView.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel IsItemsHost="True"/>
                </ItemsPanelTemplate>
            </ListView.ItemsPanel>
        </ListView>

        <!-- Layer 3: Edge trigger zones (invisible, 50px) -->
        <Border x:Name="EdgeTop" Height="50" VerticalAlignment="Top"
                Background="Transparent" MouseEnter="EdgeTop_Enter"/>
        <Border x:Name="EdgeLeft" Width="50" HorizontalAlignment="Left"
                Background="Transparent" MouseEnter="EdgeLeft_Enter"/>
        <Border x:Name="EdgeBottom" Height="50" VerticalAlignment="Bottom"
                Background="Transparent" MouseEnter="EdgeBottom_Enter"/>

        <!-- Layer 4: Right-bottom overlay info -->
        <StackPanel HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="8">
            <TextBlock x:Name="ZoomText" Text="100%" Foreground="#FF666666" FontSize="10"
                       HorizontalAlignment="Right"/>
            <TextBlock x:Name="PageInfo" Foreground="#FF666666" FontSize="10"
                       HorizontalAlignment="Right"/>
        </StackPanel>

        <!-- Layer 5: Welcome guide (shown when no folder loaded) -->
        <StackPanel x:Name="WelcomePanel" HorizontalAlignment="Center" VerticalAlignment="Center"
                    Margin="0,-40,0,0">
            <TextBlock Text="PureViewer" Foreground="#FF888888" FontSize="32"
                       HorizontalAlignment="Center" FontWeight="Light" Margin="0,0,0,16"/>
            <TextBlock Foreground="#FF777777" FontSize="13" TextAlignment="Center" LineHeight="28">
                <Run Text="右键点击窗口"/><Run Text=" → "/><Run Text="选择文件夹"/><Run Text="  加载图片"/><LineBreak/>
                <Run Text="滚轮"/><Run Text="  翻页"/><Run Text="    "/>
                <Run Text="← → / A D"/><Run Text="  导航"/><LineBreak/>
                <Run Text="F11 / F"/><Run Text="  全屏"/><Run Text="    "/>
                <Run Text="G"/><Run Text="  缩略图视图"/><LineBreak/>
                <Run Text="Ctrl+F"/><Run Text="  搜索"/><Run Text="    "/>
                <Run Text="Tab"/><Run Text="  作者列表"/><LineBreak/>
                <Run Text="Ctrl+滚轮 / +−"/><Run Text="  缩放"/><Run Text="    "/>
                <Run Text="Ctrl+0"/><Run Text="  重置缩放"/>
            </TextBlock>
        </StackPanel>

        <!-- Layer 6: Loading indicator -->
        <TextBlock x:Name="LoadingText" Text="加载中…"
                   HorizontalAlignment="Center" VerticalAlignment="Center"
                   Foreground="#FFAAAAAA" FontSize="18" Visibility="Collapsed"/>

        <!-- Floating Popups (positioned by code, rendered above all layers) -->

        <!-- Top panel: Search + Tag + Subfolders -->
        <Popup x:Name="TopPanel" Placement="Absolute" AllowsTransparency="True"
               PopupAnimation="Slide" StaysOpen="False">
            <Border Background="#CC222222" CornerRadius="0,0,6,6" Padding="12,8"
                    Width="600" MouseLeave="Panel_MouseLeave">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="搜索" Foreground="#FFAAAAAA" FontSize="11"
                               VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBox x:Name="SearchBox" Width="200" VerticalAlignment="Center"
                             Background="#CC444444" Foreground="#FFCCCCCC" BorderBrush="#FF666666"
                             Padding="6,3" FontSize="12" Tag="搜索文件名…"
                             TextChanged="SearchBox_TextChanged"
                             GotFocus="SearchBox_GotFocus" LostFocus="SearchBox_LostFocus"/>
                    <TextBlock Text="标签" Foreground="#FFAAAAAA" FontSize="11"
                               VerticalAlignment="Center" Margin="12,0,6,0"/>
                    <ComboBox x:Name="TagFilter" Width="180" VerticalAlignment="Center"
                              Background="#CC444444" Foreground="#FFCCCCCC"
                              BorderBrush="#FF666666" Padding="6,3" FontSize="12"
                              SelectionChanged="TagFilter_SelectionChanged"/>
                    <CheckBox x:Name="IncludeSubfolders" VerticalAlignment="Center"
                              Foreground="#FFCCCCCC" Content="含子文件夹" Margin="12,0,0,0"/>
                </StackPanel>
            </Border>
        </Popup>

        <!-- Left panel: Author list -->
        <Popup x:Name="LeftPanel" Placement="Absolute" AllowsTransparency="True"
               PopupAnimation="Slide" StaysOpen="False">
            <Border Background="#CC222222" CornerRadius="0,6,6,0" Padding="8"
                    Width="200" MaxHeight="500" MouseLeave="Panel_MouseLeave">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="作者列表" Foreground="#FFCCCCCC"
                               FontSize="13" Margin="4,2" FontWeight="Bold"/>
                    <ListView x:Name="AuthorList" SelectionChanged="AuthorList_SelectionChanged"
                              Background="Transparent" BorderThickness="0"
                              Foreground="#FFCCCCCC" FontSize="12" MaxHeight="460"/>
                </DockPanel>
            </Border>
        </Popup>

        <!-- Bottom panel: Navigation controls -->
        <Popup x:Name="BottomPanel" Placement="Absolute" AllowsTransparency="True"
               PopupAnimation="Slide" StaysOpen="False">
            <Border Background="#CC222222" CornerRadius="6,6,0,0" Padding="12,8"
                    MouseLeave="Panel_MouseLeave">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button Content="◀ 上一张" Click="Prev_Click" Margin="3" Padding="10,4"/>
                    <Button Content="下一张 ▶" Click="Next_Click" Margin="3" Padding="10,4"/>
                    <Button Content="全屏" Click="Fullscreen_Click" Margin="3" Padding="10,4"/>
                    <Button Content="退出全屏" Click="ExitFullscreen_Click" Margin="3" Padding="10,4"/>
                    <Button x:Name="ToggleViewBtn" Content="缩略图" Click="ToggleView_Click"
                            Margin="12,3,3,3" Padding="10,4"/>
                </StackPanel>
            </Border>
        </Popup>
    </Grid>
</Window>
