<Window x:Class="PureViewer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PureViewer" Height="600" Width="1000"
        Background="#FF1E1E1E"
        KeyDown="Window_KeyDown"
        MouseWheel="Window_MouseWheel"
        MouseMove="Window_MouseMove"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#FF555555"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#FF666666"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1" Padding="{TemplateBinding Padding}"
                                CornerRadius="3">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FF777777"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ListViewItem">
            <Setter Property="Foreground" Value="#FFCCCCCC"/>
            <Setter Property="Background" Value="Transparent"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#FF555555"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FF4A4A4A"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <DataTemplate x:Key="ThumbTemplate">
            <Border Background="#FF2A2A2A" Margin="4" CornerRadius="4" Width="140">
                <StackPanel>
                    <Image Source="{Binding Thumbnail}" Width="120" Height="120"
                           Stretch="Uniform" Margin="8,8,8,4"/>
                    <TextBlock Text="{Binding FileName}" Foreground="#FFAAAAAA" FontSize="10"
                               TextTrimming="CharacterEllipsis" TextWrapping="NoWrap"
                               HorizontalAlignment="Center" Margin="4,0,4,6"/>
                </StackPanel>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <!-- Root: Grid with layered overlays -->
    <Grid x:Name="RootGrid" Background="#FF1E1E1E">

        <!-- Layer 1: Image viewer (full window) -->
        <ScrollViewer x:Name="ImageScroll" HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Disabled" Background="#FF1E1E1E"
                      PreviewMouseWheel="ImageScroll_PreviewMouseWheel">
            <Image x:Name="ImageViewer" Stretch="Uniform"
                   RenderTransformOrigin="0.5,0.5"
                   MouseLeftButtonDown="ImageViewer_MouseLeftButtonDown"
                   MouseLeftButtonUp="ImageViewer_MouseLeftButtonUp"
                   MouseMove="ImageViewer_MouseMove">
                <Image.RenderTransform>
                    <ScaleTransform x:Name="ImageScale" ScaleX="1" ScaleY="1"/>
                </Image.RenderTransform>
            </Image>
        </ScrollViewer>

        <!-- Layer 2: Thumbnail grid (full window) -->
        <ListView x:Name="ThumbGrid" Visibility="Collapsed"
                  ItemTemplate="{StaticResource ThumbTemplate}"
                  SelectionChanged="ThumbGrid_SelectionChanged"
                  Background="#FF1E1E1E" BorderThickness="0"
                  Foreground="#FFCCCCCC"
                  ScrollViewer.HorizontalScrollBarVisibility="Disabled">
            <ListView.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel IsItemsHost="True"/>
                </ItemsPanelTemplate>
            </ListView.ItemsPanel>
        </ListView>

        <!-- Layer 3: Author sidebar (left, floating, semi-transparent) -->
        <Border x:Name="AuthorSidebar" Visibility="Collapsed"
                HorizontalAlignment="Left" VerticalAlignment="Stretch"
                Width="180" Background="#CC222222"
                Margin="0,40,0,44"
                MouseEnter="Panel_MouseEnter" MouseLeave="Panel_MouseLeave">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="作者列表" Foreground="#FFCCCCCC"
                           FontSize="13" Margin="8,6" FontWeight="Bold"/>
                <ListView x:Name="AuthorList" SelectionChanged="AuthorList_SelectionChanged"
                          Background="Transparent" BorderThickness="0"
                          Foreground="#FFCCCCCC" FontSize="12" Margin="2"/>
            </DockPanel>
        </Border>

        <!-- Layer 4: Top bar (floating, semi-transparent) -->
        <Border x:Name="TopBar" HorizontalAlignment="Stretch" VerticalAlignment="Top"
                Background="#CC222222" Padding="8,6"
                MouseEnter="Panel_MouseEnter" MouseLeave="Panel_MouseLeave">
            <StackPanel Orientation="Horizontal">
                <Button Content="选择文件夹" Click="SelectFolder_Click" Padding="10,4" Margin="0,0,6,0"/>
                <CheckBox x:Name="IncludeSubfolders" VerticalAlignment="Center"
                          Foreground="#FFCCCCCC" Content="含子文件夹" Margin="0,0,6,0"/>
                <TextBlock x:Name="FolderText" VerticalAlignment="Center" Foreground="#FFCCCCCC"
                           Text="未选择文件夹" FontSize="12" Margin="0,0,10,0"/>
                <TextBox x:Name="SearchBox" Width="180" VerticalAlignment="Center"
                         Background="#CC444444" Foreground="#FFCCCCCC" BorderBrush="#FF666666"
                         Padding="6,3" Tag="搜索文件名…"
                         TextChanged="SearchBox_TextChanged"
                         GotFocus="SearchBox_GotFocus" LostFocus="SearchBox_LostFocus"
                         MouseEnter="Panel_MouseEnter"/>
                <ComboBox x:Name="TagFilter" Width="150" VerticalAlignment="Center"
                          Margin="6,0,0,0" Background="#CC444444" Foreground="#FFCCCCCC"
                          BorderBrush="#FF666666" Padding="6,3"
                          SelectionChanged="TagFilter_SelectionChanged"
                          MouseEnter="Panel_MouseEnter"/>
            </StackPanel>
        </Border>

        <!-- Layer 5: Bottom bar (floating, semi-transparent) -->
        <Border x:Name="BottomBar" HorizontalAlignment="Stretch" VerticalAlignment="Bottom"
                Background="#CC222222" Padding="8,6"
                MouseEnter="Panel_MouseEnter" MouseLeave="Panel_MouseLeave">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button Content="◀ 上一张" Click="Prev_Click" Margin="3" Padding="10,4"/>
                <Button Content="下一张 ▶" Click="Next_Click" Margin="3" Padding="10,4"/>
                <Button Content="全屏" Click="Fullscreen_Click" Margin="3" Padding="10,4"/>
                <Button Content="退出全屏" Click="ExitFullscreen_Click" Margin="3" Padding="10,4"/>
                <Button x:Name="ToggleViewBtn" Content="缩略图" Click="ToggleView_Click" Margin="12,3,3,3" Padding="10,4"/>
                <TextBlock x:Name="ZoomText" Text="100%" VerticalAlignment="Center"
                           Foreground="#FF888888" FontSize="11" Margin="8,0,0,0"/>
            </StackPanel>
        </Border>

        <!-- Layer 6: Loading indicator -->
        <TextBlock x:Name="LoadingText" Text="加载中…"
                   HorizontalAlignment="Center" VerticalAlignment="Center"
                   Foreground="#FFAAAAAA" FontSize="18" Visibility="Collapsed"/>
    </Grid>
</Window>
