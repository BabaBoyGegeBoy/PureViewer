<Window x:Class="PureViewer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PureViewer" Height="600" Width="900"
        Background="#FF3C3C3C"
        KeyDown="Window_KeyDown"
        WindowStartupLocation="CenterScreen">
    <DockPanel Background="#FF3C3C3C">
        <!-- Top: Folder selection -->
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="8">
            <Button Content="选择文件夹" Click="SelectFolder_Click"
                    Padding="12,6" Margin="0,0,8,0" Background="#FF555555" Foreground="White"/>
            <CheckBox x:Name="IncludeSubfolders" VerticalAlignment="Center"
                      Foreground="#FFCCCCCC" Content="含子文件夹" Margin="0,0,8,0"/>
            <TextBlock x:Name="FolderText" VerticalAlignment="Center" Foreground="#FFCCCCCC"
                       Text="未选择文件夹" FontSize="13"/>
        </StackPanel>

        <!-- Bottom: Controls -->
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                    HorizontalAlignment="Center" Margin="8">
            <Button Content="◀ 上一张 (←/A)" Click="Prev_Click" Margin="4"
                    Padding="12,6" Background="#FF555555" Foreground="White"/>
            <Button Content="下一张 (→/D) ▶" Click="Next_Click" Margin="4"
                    Padding="12,6" Background="#FF555555" Foreground="White"/>
            <Button Content="全屏 (F11)" Click="Fullscreen_Click" Margin="4"
                    Padding="12,6" Background="#FF555555" Foreground="White"/>
            <Button Content="退出全屏 (Esc)" Click="ExitFullscreen_Click" Margin="4"
                    Padding="12,6" Background="#FF555555" Foreground="White"/>
        </StackPanel>

        <!-- Center: Image -->
        <Image x:Name="ImageViewer" Stretch="Uniform" Margin="4"/>
    </DockPanel>
</Window>
